
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().primaryRoleCode == role;
    }
    
    function isOwner() {
      return hasRole('OWNER') || hasRole('DEVELOPER');
    }
    
    function isStaff() {
      return hasRole('ADMIN') || hasRole('STAFF') || hasRole('MEKANIK') || hasRole('DRIVER');
    }
    
    function hasPermission(permission) {
      return isAuthenticated() && 
        (getUserData().permissions.hasAny([permission]) || isOwner());
    }
    
    function isBranchMember(branchId) {
      return isAuthenticated() && 
        (getUserData().branchId == branchId || isOwner());
    }
    
    function isCreator(resource) {
      return isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    
    // ==================== COLLECTION RULES ====================
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (isStaff() && (resource.data.branchId == getUserData().branchId || resource.data.id == request.auth.uid))
      );
      allow create: if isOwner() || (hasRole('ADMIN') && request.resource.data.branchId == getUserData().branchId);
      allow update: if isOwner() || 
        (hasRole('ADMIN') && resource.data.branchId == getUserData().branchId && resource.data.primaryRoleCode != 'OWNER') ||
        (userId == request.auth.uid);
      allow delete: if isOwner() || 
        (hasRole('ADMIN') && resource.data.branchId == getUserData().branchId && resource.data.primaryRoleCode != 'OWNER');
    }
    
    match /branches/{branchId} {
      allow read: if true; // Public can read branches for booking
      allow write: if isOwner();
    }
    
    match /invoices/{invoiceId} {
      allow read: if isOwner() || isBranchMember(resource.data.branchId);
      allow create: if isOwner() || (isStaff() && request.resource.data.branchId == getUserData().branchId);
      allow update: if isOwner() || (isStaff() && resource.data.branchId == getUserData().branchId);
      allow delete: if isOwner() || (hasRole('ADMIN') && resource.data.branchId == getUserData().branchId);
    }
    
    match /customers/{customerId} {
      allow read: if isOwner() || (isStaff() && resource.data.branchIds.hasAny([getUserData().branchId]));
      allow create: if isStaff();
      allow update: if isOwner() || (isStaff() && resource.data.branchIds.hasAny([getUserData().branchId]));
      allow delete: if isOwner();
    }

    match /units/{unitId} {
      allow read: if isStaff();
      allow write: if isOwner() || (hasRole('ADMIN') && resource.data.branchId == getUserData().branchId);
    }
    
    match /maintenance/{maintenanceId} {
      allow read: if isStaff();
      allow write: if isOwner() || (hasRole('ADMIN') && resource.data.branchId == getUserData().branchId);
    }
    
    match /activity_logs/{logId} {
      allow read: if isOwner() || isBranchMember(resource.data.branchId);
      allow create: if isStaff();
      allow update, delete: if false;
    }
    
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }
    
    match /permissions/{permissionId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }

    // Public lead creation
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
